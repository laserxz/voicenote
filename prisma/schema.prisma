generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  displayName         String
  resetToken          String?   @unique
  resetTokenExpiresAt DateTime?
  createdAt           DateTime  @default(now())

  notes Note[]
}

model Note {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String?
  transcript String
  structured Json
  noteType   NoteType
  duration   Int?
  emailedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([createdAt])
  @@index([userId, createdAt])
}

enum NoteType {
  LIST
  BRAINSTORM
  POSTMORTEM
  MEETING
  ACTION_ITEMS
  JOURNAL
  PROBLEM
  RAW
}
